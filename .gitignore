# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build"). The package is
# `ex_tempo`, so match any `*.tar` — a narrow `tempo-*.tar` missed it.
*.tar

# Temporary files for e.g. tests
/tmp

# Mac artifact
.DS_Store

# Claude (local settings/state; the distributable skill lives in skills/)
.claude

# Mise and asdf
mise.toml
.tool-versions

# Test iCal file (has personal data in it)
ical_apple_example_export.ics

# Copyrighted ISO 8601 standard PDFs — reference only, never distributed
/papers/iso8601_specs/

# Copyrighted reference paper — not distributed
/papers/Levy-et-al-ChronoNetworks-JAS.pdf

# ANBIMA holiday data (downloaded source + generated iCalendar) —
# normative pricing data users pin locally per the cookbook; not distributed
/scripts/feriados_anbima.ics
/scripts/feriados_nacionais.xls

# ISO8601 standards
/iso8601/
